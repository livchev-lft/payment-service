# API
API_KEY=dev-secret-key
APP_PORT=8000

# PostgreSQL
POSTGRES_USER=payments
POSTGRES_PASSWORD=payments
POSTGRES_DB=payments
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Payment processing emulation
PROCESSING_MIN_SECONDS=2
PROCESSING_MAX_SECONDS=5
PROCESSING_FAILURE_RATE=0.1

# Retry
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000

# Outbox relay
OUTBOX_POLL_INTERVAL_SECONDS=1
OUTBOX_BATCH_SIZE=50

# Testing
# Required only for pytest — the test suite connects to Postgres directly.
# docker-compose does not need this variable.
# TEST_DATABASE_URL=postgresql+asyncpg://payments:payments@localhost:5432/payments
